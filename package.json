{
  "name": "church-giving-management",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev -p 7000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:db:reset": "tsx scripts/test-db-reset.ts",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "prisma:generate": "prisma generate && prettier --write lib/graphql/pothos-prisma-types.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "rock:discover": "tsx scripts/rock-discovery.ts",
    "rock:sync": "tsx scripts/rock-sync.ts",
    "rock:sync-person": "tsx scripts/rock-sync-person.ts",
    "sync:enqueue": "tsx scripts/sync-enqueue.ts",
    "sync:enqueue-person": "tsx scripts/sync-enqueue-person.ts",
    "sync:schedule": "tsx scripts/sync-schedule.ts",
    "sync:schedule-person": "tsx scripts/sync-schedule-person.ts",
    "sync:worker": "tsx scripts/sync-worker.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "4.16.2",
    "@envelop/core": "5.5.1",
    "@pothos/core": "4.12.0",
    "@pothos/plugin-prisma": "4.14.3",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "graphql": "16.13.2",
    "graphql-yoga": "5.21.0",
    "lucide-react": "1.8.0",
    "motion": "12.38.0",
    "next": "16.2.3",
    "pg": "8.16.3",
    "pg-boss": "12.15.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "prettier": "3.8.2",
    "prisma": "7.7.0",
    "tailwindcss": "4.2.1",
    "tsx": "4.20.6",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  }
}
