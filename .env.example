DATABASE_URL="postgresql://user:password@localhost:5432/church_giving_management"

# Test database
# TEST_DATABASE_URL is used by database-backed integration tests only.
# Keep it separate from DATABASE_URL so fixture/demo records never pollute the
# local development database that may contain live read-only Rock sync data.
# The database name must include "test" for `pnpm test:db:reset` to run.
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/church_giving_management_test"

# Auth0
# Create or open an Auth0 Regular Web Application in the Auth0 dashboard.
# AUTH0_DOMAIN: Auth0 Dashboard > Applications > your app > Settings > Domain.
# AUTH0_CLIENT_ID: same Settings page > Client ID.
# AUTH0_CLIENT_SECRET: same Settings page > Client Secret.
# AUTH0_SECRET: generate a local app session secret, for example:
#   openssl rand -hex 32
# APP_BASE_URL: this app's public origin. Auth0 redirects back to this app, so
# it should match the domain used in your Auth0 callback/logout/web-origin URLs.
#
# In the Auth0 app settings, configure:
# Allowed Callback URLs: http://localhost:3000/auth/callback
# Allowed Logout URLs: http://localhost:3000
# Allowed Web Origins: http://localhost:3000
AUTH0_DOMAIN="example.us.auth0.com"
AUTH0_CLIENT_ID="replace-me"
AUTH0_CLIENT_SECRET="replace-me"
AUTH0_SECRET="replace-with-32-byte-secret"
APP_BASE_URL="http://localhost:3000"

# Rock RMS
# ROCK_BASE_URL: the base URL for the church's Rock instance, without a trailing slash.
# ROCK_REST_KEY: create or copy the REST key in Rock:
#   Rock > Admin Tools > Security > REST Keys
# This Rock instance does not currently have a separate read-only REST role, so
# app code must only issue GET requests and must treat this as a high-risk secret.
# Grant only the API/controller permissions needed for discovery/sync when possible:
#   Rock > Admin Tools > Security > REST Controllers
# Keep real Rock values in .env.local or a secret manager. Never commit REST keys.
ROCK_BASE_URL="https://rock.example.org"
ROCK_REST_KEY=""

# Optional scheduled sync cadence used by pg-boss full-sync scripts.
ROCK_SYNC_CRON="0 * * * *"
